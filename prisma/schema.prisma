generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  MEMBER
}

enum CardStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ContentType {
  POST
  STORY
  REELS
  CAROUSEL
  ADS
}

enum Effort {
  LOW
  MEDIUM
  HIGH
}

enum ProductionStage {
  ROTEIRO
  DESIGN
  EDICAO
  REVISAO
  APROVACAO
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(MEMBER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  assignedCards Card[]        @relation("AssignedCards")
  activityLogs  ActivityLog[]
  cardComments  CardComment[] @relation("CommentAuthor")
}

model Client {
  id                    String   @id @default(cuid())
  name                  String
  description           String   @default("")
  niche                 String   @default("")
  toneOfVoice           String   @default("")
  mainObjective         String   @default("")
  platforms             String   @default("")
  contentFrequency      String   @default("")
  targetAudience        String   @default("")
  restrictions          String   @default("")
  differentials         String   @default("")
  operationalGuidelines String   @default("")
  customHtml            String   @default("")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  boards Board[]
}

model Board {
  id        String   @id @default(cuid())
  name      String
  clientId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  columns      Column[]
  activityLogs ActivityLog[]
}

model Column {
  id        String   @id @default(cuid())
  name      String
  order     Int
  boardId   String
  createdAt DateTime @default(now())

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]
}

model Card {
  id             String          @id @default(cuid())
  title          String
  description    String          @default("")
  objective      String          @default("")
  references     String          @default("")
  driveLink      String          @default("")
  cta            String          @default("")
  status         CardStatus      @default(TODO)
  priority       Priority        @default(MEDIUM)
  contentType    ContentType?
  platform       String          @default("")
  effort         Effort?
  stage          ProductionStage?
  deadline       DateTime?
  order          Int
  columnId       String
  assignedUserId String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  column       Column      @relation(fields: [columnId], references: [id], onDelete: Cascade)
  assignedUser User?       @relation("AssignedCards", fields: [assignedUserId], references: [id], onDelete: SetNull)
  activityLogs ActivityLog[]
  comments     CardComment[]
}

model CardComment {
  id             String   @id @default(cuid())
  content        String
  mentionUserIds String[] @default([])
  cardId         String
  authorId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  card   Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  author User @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid())
  message   String
  userId    String
  cardId    String?
  boardId   String
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  card  Card?  @relation(fields: [cardId], references: [id], onDelete: SetNull)
}
